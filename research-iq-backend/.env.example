# Database Configuration (Used in Production)
DB_URL=jdbc:postgresql://localhost:5432/researchiq_prod
DB_USERNAME=postgres
DB_PASSWORD=your_secure_database_password

# JWT Configuration
# Must be Base64-encoded and decode to at least 32 bytes for HS256
JWT_SECRET=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# OAuth2 Google Client [Not needed for now]
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth2 ORCID Client [Not needed for now]
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=your_orcid_client_secret

# Bootstrap admin credentials
BOOTSTRAP_ADMIN_EMAIL=admin@researchiq.local
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
BOOTSTRAP_ADMIN_NAME=System Admin

# AI Microservices (Python FastAPI - run from Ai_task/ folder)
AI_EXPERTISE_URL=http://localhost:8001
AI_COLLABORATION_URL=http://localhost:8002
AI_TREND_URL=http://localhost:8003
AI_FUNDING_URL=http://localhost:8004

# Email / OTP delivery (Gmail SMTP)
# OTP is used for: signup email verification, admin MFA login, password reset.
# OTP codes are ALWAYS printed in the backend terminal as well (even when email is configured).
# Look for: "admin MFA OTP for your@gmail.com: 123456"
#
# Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords (regular Gmail password may not work).
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# OAuth2 Google Client [Not needed for now]
